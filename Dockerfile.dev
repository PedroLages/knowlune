# Development Dockerfile for LevelUp
# Uses Node 20 Alpine for minimal footprint with hot reload support

FROM node:20-alpine

# Set working directory
WORKDIR /app

# Install dependencies for better compatibility
RUN apk add --no-cache \
    python3 \
    make \
    g++

# Copy package files
COPY package.json package-lock.json* ./

# Install dependencies
RUN npm ci

# Copy application files (volumes will override these in docker-compose)
COPY . .

# Expose Vite dev server port
EXPOSE 5173

# Enable file watching with polling for Docker compatibility
ENV CHOKIDAR_USEPOLLING=true

# Start Vite dev server with host binding for external access
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
