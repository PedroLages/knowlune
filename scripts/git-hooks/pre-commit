#!/bin/bash
# Pre-commit hook to enforce code quality before commits
# Prevents ESLint/TypeScript/format errors from reaching CI

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}🔍 Pre-commit hook: Running quality checks...${NC}"
echo ""

# Track if any checks fail
FAILED=0

# 1. TypeScript type checking
echo -e "${YELLOW}⚙️  Running TypeScript checks...${NC}"
if ! npm run typecheck; then
    echo -e "${RED}❌ TypeScript errors detected${NC}"
    FAILED=1
else
    echo -e "${GREEN}✅ TypeScript checks passed${NC}"
fi
echo ""

# 2. ESLint
echo -e "${YELLOW}⚙️  Running ESLint...${NC}"
if ! npm run lint; then
    echo -e "${RED}❌ ESLint errors detected${NC}"
    FAILED=1
else
    echo -e "${GREEN}✅ ESLint checks passed${NC}"
fi
echo ""

# 3. Prettier format checking
echo -e "${YELLOW}⚙️  Running Prettier format check...${NC}"
if ! npm run format:check; then
    echo -e "${RED}❌ Formatting issues detected${NC}"
    echo -e "${YELLOW}💡 Fix with: npm run format${NC}"
    FAILED=1
else
    echo -e "${GREEN}✅ Format checks passed${NC}"
fi
echo ""

# If any check failed, block the commit
if [ $FAILED -eq 1 ]; then
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}❌ COMMIT BLOCKED: Quality checks failed${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo -e "${YELLOW}Fix the errors above and try again.${NC}"
    echo ""
    echo -e "${YELLOW}To bypass this hook (NOT recommended):${NC}"
    echo "  git commit --no-verify"
    exit 1
fi

echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${GREEN}✅ All quality checks passed!${NC}"
echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
exit 0
