#!/usr/bin/env bash
# pre-commit-secrets-scan — block commits containing hardcoded credentials
#
# Scans staged changes for high-entropy strings and credential patterns
# (API keys, passwords, tokens, secrets). Uses the same patterns as
# grep-gate-credentials.sh with additional entropy heuristics.
#
# Installation:
#   ln -sf ../../scripts/git-hooks/pre-commit-secrets-scan .git/hooks/pre-commit
#
# Or set core.hooksPath globally:
#   git config core.hooksPath .githooks

set -euo pipefail

# --- Build the list of staged files to scan ---
STAGED=$(git diff --cached --name-only --diff-filter=ACM)
if [ -z "$STAGED" ]; then
  exit 0
fi

# --- Patterns that signal hardcoded credentials ---
# These are intentionally broad at the signal level; false positives
# are filtered below in the file/path exclusion step.
PATTERNS=(
  # API key / token patterns
  'api[_-]?key\s*[:=]\s*['\''"][A-Za-z0-9_\-]{8,}'
  'api[_-]?secret\s*[:=]\s*['\''"][A-Za-z0-9_\-]{8,}'
  'secret\s*[:=]\s*['\''"][A-Za-z0-9_\-+/]{8,}'
  'password\s*[:=]\s*['\''"][A-Za-z0-9_\-!@#$%^&*()]{4,}'
  'token\s*[:=]\s*['\''"][A-Za-z0-9_\-.]{8,}'
  'access[_-]?key\s*[:=]\s*['\''"][A-Za-z0-9_\-]{8,}'
  # Supabase keys
  'eyJ[A-Za-z0-9_\-]{20,}\.[A-Za-z0-9_\-]{20,}\.[A-Za-z0-9_\-]{10,}'
  # Stripe keys
  'sk_live_[A-Za-z0-9]{20,}'
  'pk_live_[A-Za-z0-9]{20,}'
)

# --- Paths to exclude (test fixtures, docs, vendored deps) ---
EXCLUDE_PATTERNS=(
  'node_modules/'
  '.git/'
  'test-results/'
  'playwright-report/'
  'coverage/'
  '__tests__/'
  '__snapshots__/'
  'package-lock.json'
  'docs/'
  '.claude/'
)

VIOLATIONS=0
while IFS= read -r file; do
  # Skip excluded paths
  skip=false
  for exclude in "${EXCLUDE_PATTERNS[@]}"; do
    case "$file" in
      *"$exclude"*) skip=true; break ;;
    esac
  done
  [ "$skip" = true ] && continue

  for pattern in "${PATTERNS[@]}"; do
    if git diff --cached "$file" | grep -nE "$pattern" > /dev/null 2>&1; then
      echo "SECRET: $file matches pattern: $pattern"
      VIOLATIONS=$((VIOLATIONS + 1))
      break
    fi
  done
done <<< "$STAGED"

if [ "$VIOLATIONS" -gt 0 ]; then
  echo ""
  echo "❌ Pre-commit blocked: $VIOLATIONS file(s) contain potential secrets."
  echo "   Review each match above. If this is a false positive (test mock data,"
  echo "   documentation, etc.), bypass with: git commit --no-verify"
  echo ""
  exit 1
fi

exit 0
