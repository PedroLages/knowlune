{
  "name": "level-up",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "lint": "eslint .",
    "test": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx,css,md}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,js,jsx,css,md}'",
    "test:unit": "vitest run --project unit --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "ci": "npm run typecheck && npm run lint && npm run format:check && npm run build && npm run test:unit",
    "ci:docker": "docker-compose -f docker-compose.ci.yml --profile ci up --abort-on-container-exit --exit-code-from ci-full",
    "preview": "vite preview",
    "lighthouse": "lhci autorun",
    "lighthouse:collect": "lhci collect",
    "lighthouse:assert": "lhci assert",
    "lighthouse:upload": "lhci upload",
    "lighthouse:docker": "docker-compose -f docker-compose.test.yml --profile lighthouse up --abort-on-container-exit"
  },
