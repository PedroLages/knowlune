# Supabase Auth — get these from your Supabase dashboard (Settings > API)
# Dev (local): http://localhost:8000 via Kong, OR a Cloud project (simpler)
# Prod: Supabase Cloud — https://<project-ref>.supabase.co
# Prod env vars live in the Cloudflare Pages dashboard, not this file.
# See docs/deployment/cloudflare-pages-setup.md.
VITE_SUPABASE_URL=http://localhost:8000
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Edge Function Secrets — set via Supabase `.env` (self-hosted) or `supabase secrets set <NAME>=<VALUE>` (cloud).
# (These are never exposed to the frontend; they live only in Supabase Edge Function env.)
#
# IMPORTANT for self-hosted Supabase: each secret must be added in THREE places:
#   1. Supabase stack `.env` (e.g. /mnt/cache/docker/stacks/supabase/.env on titan)
#   2. The `environment:` block of the `functions` service in docker-compose.yml
#   3. The `WORKER_ENV_ALLOWLIST` in supabase/functions/main/index.ts
# Missing step 3 results in Deno.env.get() returning undefined inside the worker,
# silently bypassing auth checks (the function continues to run without validation).
# See fix history at commits 50a5ddfa (RETENTION_TICK_SECRET) and 445a6f39 (EXPORT_WORKER_SECRET).

# RETENTION_TICK_SECRET: Shared secret authorising the daily retention-tick cron (E119-S11).
# Generate with: openssl rand -base64 32
# Also set on the Cloudflare Worker: `wrangler secret put RETENTION_TICK_SECRET`.
# If absent, the Edge Function warns and permits unauthenticated requests.
# RETENTION_TICK_SECRET=your_secret_here

# EXPORT_WORKER_SECRET: Shared secret authorising export-data to invoke export-worker (E119-S06).
# Generate with: openssl rand -base64 32
# Set on BOTH export-data and export-worker env (same value; they share one Supabase `functions` container).
# If absent: jobs are enqueued but worker is not triggered; worker endpoint runs unauthenticated.
# EXPORT_WORKER_SECRET=your_secret_here

# Stripe — client-side vars (checkout is server-side redirect; these are optional)
# VITE_STRIPE_PRICE_ID=price_xxx

# Server-Side Middleware — required for premium API endpoint protection
# JWT secret from Supabase dashboard (Settings > API > JWT Secret)
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here
# Service role key for server-side Supabase queries (Settings > API > Service Role Key)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Comma-separated list of allowed origins for CORS/origin checking
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Dev-only: bypass all auth/entitlement checks in the Vite dev proxy.
# Set to "true" in .env.local for local development without Supabase.
# A console warning is logged when active. Never use in production.
# DEV_SKIP_ENTITLEMENT=true

# VITE_API_BASE_URL — base URL for Supabase Edge Functions + iCal calendar feed.
# Post-Cloud-migration (Unit 5): https://<project-ref>.supabase.co/functions/v1
# Consumed by src/lib/apiBaseUrl.ts; falls back to relative /api/* when unset.
# Local dev: leave unset to hit the Vite dev proxy / Express server on :3001.
# Prod: set in the Cloudflare Pages dashboard (baked in at build time by Vite).
# VITE_API_BASE_URL=https://chyvhrbtttpumsyuhgbu.supabase.co/functions/v1

# Sentry — Error reporting (optional, graceful no-op when not set)
# Get your DSN from https://sentry.io → Project Settings → Client Keys
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
