# E-Learning Platform Environment Variables

# API Configuration
# URL for the mock API backend (Mockoon)
# In Docker: http://mock-api:3000/api
# In local development: http://localhost:3000/api
VITE_API_URL=http://localhost:3000/api

# Development Settings
NODE_ENV=development

# Vite Server Configuration
VITE_HOST=0.0.0.0
VITE_PORT=5173

# Optional: Enable API request logging
VITE_API_DEBUG=false

# Optional: API request timeout (milliseconds)
VITE_API_TIMEOUT=30000
