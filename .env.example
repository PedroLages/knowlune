# Supabase Auth — get these from your Supabase dashboard (Settings > API)
# Dev: use Kong direct (e.g., http://your-server:8000)
# Prod: use HTTPS reverse proxy (e.g., https://supabase.yourdomain.com)
VITE_SUPABASE_URL=http://localhost:8000
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Stripe — Edge Function secrets are configured via `supabase secrets set`
# These client-side vars are optional (checkout is a server-side redirect)
# VITE_STRIPE_PRICE_ID=price_xxx

# Sentry — Error reporting (optional, graceful no-op when not set)
# Get your DSN from https://sentry.io → Project Settings → Client Keys
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
