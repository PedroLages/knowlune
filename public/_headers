# Cloudflare Pages HTTP headers
# These apply at the CDN level before the HTML <meta> CSP tag is parsed,
# providing a first line of defense and proper asset caching.

# === Security Headers (apply before CSP meta tag is parsed) ===
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# === SPA entry point — never cache (prevents stale SW precache of index.html) ===
/index.html
  Cache-Control: no-cache

# === Hashed assets — immutable long-term cache (safe because hashes change on rebuild) ===
/assets/*.js
  Cache-Control: public, max-age=31536000, immutable

/assets/*.css
  Cache-Control: public, max-age=31536000, immutable

/assets/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# === Service worker — short cache to ensure updates propagate quickly ===
/sw.js
  Cache-Control: no-cache

/workbox-*.js
  Cache-Control: no-cache
